{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cobase",
  "version": "0.1.0",
  "identifier": "com.cobase.product",
  "build": {
    "beforeDevCommand": "vite --host 0.0.0.0 --port 3040",
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:3040",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cobase",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 12
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns"
    ]
  }
}
